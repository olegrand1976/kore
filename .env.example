# Kore — environnement local
# Ports hôte (évitent les conflits avec d'autres projets Docker)
KORE_API_PORT=8081
KORE_FRONTEND_PORT=3001
KORE_DB_PORT=5434
KORE_REDIS_PORT=6381
KORE_MAILHOG_SMTP_PORT=1025
KORE_MAILHOG_UI_PORT=8025
KORE_STRIPE_MOCK_PORT=12111

HTTP_ADDR=:8080
DATABASE_URL=postgres://kore:kore@db:5432/kore?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_DB=0
REDIS_KEY_PREFIX=kore
REDIS_AUTH=
REDIS_TLS=false
CACHE_DEFAULT_TTL=5m
JWT_SIGNING_KEY=dev-insecure-change-me-in-production
JWT_TTL=15m
JWT_REFRESH_TTL=168h
MIGRATE_ON_BOOT=true
DEV_SEED_ENABLED=true
UPLOADS_DIR=/data/uploads
LOG_LEVEL=info
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@kore.local
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_test
STRIPE_PUBLISHABLE_KEY=pk_test_mock
BILLING_TRIAL_DAYS=14
PLATFORM_ADMIN_LOGINS=ADM_admin
NUXT_PUBLIC_API_BASE=http://api:8080
NUXT_API_BASE=http://api:8080
NUXT_PUBLIC_MAILHOG_UI_URL=http://localhost:8025
NUXT_PUBLIC_SHOW_MAILHOG_HINT=true

# SSO Google OIDC (OAuth 2.0 — Google Cloud Console > Credentials)
# Redirect URI autorisée : http://localhost:3001/login
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=

# IA — Gemini (stub si absent)
AI_LLM_PROVIDER=stub
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
PROMPT_GUARD_BLOCK=true

# GCP déploiement (infra scripts)
GCP_PROJECT_ID=premedica-prod-2025
GCP_PROJECT_NUMBER=237481297060
# Clé Gemini : renseigner dans .env.gemini (voir .env.gemini.example)
